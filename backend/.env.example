# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# MiniMax API key — obtained from the MiniMax platform dashboard.
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax endpoint that speaks the Anthropic Messages API protocol.
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1

# Model identifier — use MiniMax-M2.7 (standard) or MiniMax-M2.5 (legacy).
MINIMAX_MODEL=MiniMax-M2.7

# Maximum tokens the model may generate per extraction call.
LLM_MAX_TOKENS=4096
